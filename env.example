# NeonDB
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=verify-full

# PayloadCMS
PAYLOAD_SECRET=change-me-to-a-random-32-char-string

# BetterAuth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-to-another-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@mgarts.co.in

# S3 / MinIO
S3_BUCKET_NAME=mgarts
S3_ENDPOINT=https://your-minio-endpoint
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
